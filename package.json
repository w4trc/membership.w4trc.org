{
  "name": "karc-membership",
  "version": "1.0.0",
  "description": "Kingsport Amateur Radio Club - Membership Management System",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "dotenv -e .env -- wrangler deploy",
    "db:init": "dotenv -e .env -- wrangler d1 execute karc-membership --remote --file=schema/001_initial.sql",
    "db:seed": "dotenv -e .env -- wrangler d1 execute karc-membership --remote --file=schema/002_seed.sql",
    "db:init:local": "wrangler d1 execute karc-membership --local --file=schema/001_initial.sql",
    "db:seed:local": "wrangler d1 execute karc-membership --local --file=schema/002_seed.sql",
    "db:migrate": "dotenv -e .env -- wrangler d1 execute karc-membership --remote --file",
    "db:migrate:local": "wrangler d1 execute karc-membership --local --file",
    "setup-admin": "node scripts/setup-admin.js"
  },
  "devDependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv-cli": "^11.0.0",
    "wrangler": "^4.90.1"
  }
}
